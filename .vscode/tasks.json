{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Debug",
            "type": "shell",
            "command": "make",
            "args": ["debug"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"],
            "detail": "Build debug version with symbols"
        },
        {
            "label": "Build Release",
            "type": "shell",
            "command": "make",
            "args": ["all"],
            "group": "build",
            "problemMatcher": ["$gcc"],
            "detail": "Build optimized release version"
        },
        {
            "label": "Build Tests",
            "type": "shell",
            "command": "make",
            "args": ["run_tests"],
            "group": "build",
            "problemMatcher": ["$gcc"],
            "detail": "Build unit tests"
        },
        {
            "label": "Run Tests",
            "type": "shell",
            "command": "make",
            "args": ["test"],
            "group": "test",
            "problemMatcher": ["$gcc"],
            "detail": "Build and run unit tests"
        },
        {
            "label": "Clean",
            "type": "shell",
            "command": "make",
            "args": ["clean"],
            "group": "build",
            "problemMatcher": [],
            "detail": "Clean all build artifacts"
        }
    ]
}
